# Porta local para o OpenCode Web
OPENCODE_PORT=4096

# Hostname para o opencode web (127.0.0.1 para local, 0.0.0.0 crasha dentro do proot - getifaddrs bug)
OPENCODE_HOSTNAME=127.0.0.1

# Tópico para notificação push ntfy.sh
NTFY_TOPIC=opencode-tunnel

# Diretório do projeto (onde está run-cloudflare-tunnel.sh)
PROJECT_DIR=/root/Projetos/opencode_termux
